# Formulaire de contact — EmailJS (https://dashboard.emailjs.com)
# Copier ce fichier en .env.local et renseigner les trois valeurs.
# Elles s'exécutent dans le navigateur : ce ne sont pas des secrets, mais
# .env.local reste hors du dépôt.

# Email Services → votre service
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx

# Email Templates → votre modèle
# Variables attendues : {{from_name}}, {{reply_to}}, {{subject}}, {{message}}
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx

# Account → General → Public Key
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx
